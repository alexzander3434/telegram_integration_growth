APP_ENV=dev
APP_SECRET=change_me
APP_DEBUG=1

# PostgreSQL (логин/пароль/БД должны совпадать с docker-compose и с DATABASE_URL)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=app

# Локальный PHP к PostgreSQL в Docker (127.0.0.1:5432). Спецсимволы в пароле — URL-encode в DSN.
DATABASE_URL=pgsql://postgres:postgres@127.0.0.1:5432/app?serverVersion=16&charset=utf8

# Redis (локально — к контейнеру на 127.0.0.1:6379; пароль должен совпадать с REDIS_PASSWORD в docker-compose)
REDIS_PASSWORD=redis_secret
REDIS_URL=redis://:redis_secret@127.0.0.1:6379

# 1 = эмулировать ошибку sendMessage (строка FAILED в telegram_send_log, без запроса к API)
TELEGRAM_SIMULATE_SEND_FAILURE=0
