{
  "name": "local/test-telegram-integrations",
  "type": "project",
  "license": "proprietary",
  "require": {
    "php": ">=8.4",
    "ext-ctype": "*",
    "ext-iconv": "*",
    "doctrine/doctrine-bundle": "^2.13",
    "doctrine/orm": "^3.3",
    "symfony/console": "^7.2",
    "symfony/dotenv": "^7.2",
    "symfony/cache": "^7.2",
    "symfony/framework-bundle": "^7.2",
    "symfony/http-client": "^7.2",
    "symfony/http-foundation": "^7.2",
    "symfony/lock": "^7.2",
    "symfony/messenger": "^7.2",
    "symfony/amqp-messenger": "^7.2",
    "symfony/routing": "^7.2",
    "symfony/serializer": "^7.2",
    "symfony/validator": "^7.2",
    "symfony/var-exporter": "^7.2",
    "symfony/yaml": "^7.2"
  },
  "require-dev": {
    "doctrine/doctrine-migrations-bundle": "^3.4",
    "phpunit/phpunit": "^11.5",
    "symfony/maker-bundle": "^1.62",
    "symfony/phpunit-bridge": "^7.2"
  },
  "autoload": {
    "psr-4": {
      "App\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "App\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "test": "php vendor/bin/phpunit -c phpunit.xml.dist",
    "auto-scripts": {
      "cache:clear": "symfony-cmd",
      "assets:install %PUBLIC_DIR%": "symfony-cmd"
    },
    "post-install-cmd": [
      "@auto-scripts"
    ],
    "post-update-cmd": [
      "@auto-scripts"
    ]
  },
  "config": {
    "allow-plugins": {
      "symfony/flex": true,
      "symfony/runtime": true
    },
    "sort-packages": true
  },
  "extra": {
    "symfony": {
      "allow-contrib": false,
      "require": "7.2.*"
    }
  }
}

